        <div class="budget-label">Amara Singapore</div>
        <div class="budget-amount">495<span class="budget-currency">CHF</span></div>
        <div class="budget-note">3 nuits · pour deux</div>
      </div>
      <div class="budget-item">
        <div class="budget-label">Aeropod Kota Kinabalu</div>
        <div class="budget-amount">30<span class="budget-currency">CHF</span></div>
        <div class="budget-note">1 nuit · pour deux</div>
      </div>
      <div class="budget-item">
        <div class="budget-label">Seek Sophie Bornéo</div>
        <div class="budget-amount">752<span class="budget-currency">CHF</span></div>
        <div class="budget-note">2 nuits · package</div>
      </div>
      <div class="budget-item">
        <div class="budget-label">Moxy KL Chinatown</div>
        <div class="budget-amount">110<span class="budget-currency">CHF</span></div>
        <div class="budget-note">2 nuits · pour deux</div>
      </div>
      <div class="budget-item">
        <div class="budget-label">Fift Avenue Penang</div>
        <div class="budget-amount">158<span class="budget-currency">CHF</span></div>
        <div class="budget-note">2 nuits · pour deux</div>
      </div>
      <div class="budget-item" style="background:var(--ink);color:var(--sand);">
        <div class="budget-label" style="color:rgba(245,240,232,0.5)">Total hôtels</div>
        <div class="budget-amount">1'545<span class="budget-currency" style="color:rgba(245,240,232,0.5)">CHF</span></div>
        <div class="budget-note" style="color:rgba(245,240,232,0.5)">pour deux · confirmés</div>
      </div>
    </div>
  </div>
</section>

<!-- ADD TRIP -->
<section id="add">
  <div class="add-inner">
    <div>
      <p class="section-label">Planifier</p>
      <h2 class="section-title">Ajouter<br/>un voyage</h2>
    </div>
    <button class="btn" onclick="openModal()">
      <span>+ Nouveau voyage</span>
    </button>
  </div>
</section>

<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3>Nouveau voyage</h3>
    <div class="form-group">
      <label class="form-label">Nom du voyage</label>
      <input type="text" class="form-input" id="f-name" placeholder="ex: Japon — Printemps 2027" />
    </div>
    <div class="form-group">
      <label class="form-label">Destination(s)</label>
      <input type="text" class="form-input" id="f-dest" placeholder="ex: Tokyo, Kyoto, Osaka" />
    </div>
    <div class="form-group">
      <label class="form-label">Date de départ</label>
      <input type="date" class="form-input" id="f-start" />
    </div>
    <div class="form-group">
      <label class="form-label">Date de retour</label>
      <input type="date" class="form-input" id="f-end" />
    </div>
    <div class="form-group">
      <label class="form-label">Notes</label>
      <textarea class="form-input" id="f-notes" placeholder="Idées, envies, liens utiles…"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn" onclick="saveTrip()">Enregistrer</button>
      <button class="btn-close" onclick="closeModal()">Annuler</button>
    </div>
  </div>
</div>

<footer>
  World Tour · Fait avec ♥ · <span id="year"></span>
</footer>

