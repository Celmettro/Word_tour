      { j:'Jour 15', date:'09.08', lieu:'Kuala Lumpur', hotel:'À définir', prog:'Batu Caves · Visite KL', note:'' },
      { j:'Jour 16', date:'10.08', lieu:'Kuala Lumpur → Istanbul', hotel:'Avion', prog:'Visite KL · Transfert aéroport ~20h00 · Départ 23h25', note:'' },
      { j:'Jour 17', date:'11.08', lieu:'Istanbul → Genève', hotel:'', prog:'Arrivée Genève 09h05 ✈', note:'' },
    ]
  }
];

// Stored additional trips
let extraTrips = JSON.parse(localStorage.getItem('wt-extra-trips') || '[]');

// ── WORLD MAP ─────────────────────────────────────────────────────────────────
const worldMap = L.map('map-world', {
  center: [15, 80],
  zoom: 3,
  zoomControl: true,
  scrollWheelZoom: false
});
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  maxZoom: 19
}).addTo(worldMap);

const dotIcon = L.divIcon({
  className: '',
  html: `<div style="width:10px;height:10px;border-radius:50%;background:#c8815a;border:2px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.2)"></div>`,
  iconSize: [10,10],
  iconAnchor: [5,5]
});

// Plot all destinations
TRIPS.forEach(t => {
  t.coords.forEach(c => {
    L.marker(c, { icon: dotIcon }).addTo(worldMap)
      .bindPopup(`<strong style="font-family:serif">${t.name}</strong><br/>${t.dates}`);
  });
});

// ── TRIP CARDS ────────────────────────────────────────────────────────────────
function renderTripCards() {
  const grid = document.getElementById('trips-grid');
  grid.innerHTML = '';
  const all = [...TRIPS, ...extraTrips];
  all.forEach((t, i) => {
    const div = document.createElement('div');
    div.className = 'trip-card' + (i===0 ? ' active' : '');
    div.innerHTML = `
      <div class="trip-number">0${i+1}</div>
      <div class="trip-name">${t.name}</div>
      <div class="trip-date">${t.dates || t.year}</div>
      <div class="trip-tags">${(t.tags||[]).map(tag=>`<span class="tag">${tag}</span>`).join('')}</div>
      <div class="trip-status ${t.status}">${t.statusLabel || t.status}</div>
    `;
    div.addEventListener('click', () => {
      document.querySelectorAll('.trip-card').forEach(c=>c.classList.remove('active'));
      div.classList.add('active');
      if(t.days) loadItinerary(t);
    });
    grid.appendChild(div);
  });
}

// ── TRIP MAP ──────────────────────────────────────────────────────────────────
const tripMap = L.map('map-trip', {
  scrollWheelZoom: false,
  zoomControl: true
});
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap contributors © CARTO',
  maxZoom: 19
}).addTo(tripMap);

function loadTripMap(trip) {
  tripMap.eachLayer(l => { if(l instanceof L.Marker || l instanceof L.Polyline) tripMap.removeLayer(l); });
  if(!trip.coords || !trip.coords.length) return;

  const stopIcon = (n) => L.divIcon({
    className: '',
    html: `<div style="width:22px;height:22px;border-radius:50%;background:#1a1a18;color:#f5f0e8;display:flex;align-items:center;justify-content:center;font-size:9px;font-family:serif;font-weight:600;border:2px solid white;box-shadow:0 1px 6px rgba(0,0,0,0.25)">${n}</div>`,
    iconSize: [22,22], iconAnchor: [11,11]
  });

  trip.coords.forEach((c, i) => {
    L.marker(c, { icon: stopIcon(i+1) }).addTo(tripMap);
  });
  L.polyline(trip.coords, { color: '#c8815a', weight: 1.5, opacity: 0.6, dashArray: '6,6' }).addTo(tripMap);
  tripMap.fitBounds(trip.coords, { padding: [30,30] });
}

// ── ITINERARY ─────────────────────────────────────────────────────────────────
function loadItinerary(trip) {
  document.getElementById('itin-title').textContent = trip.name;
  document.getElementById('itin-start').textContent = trip.start || '—';
  document.getElementById('itin-end').textContent = trip.end || '—';
  document.getElementById('itin-days').textContent = trip.daysCount || '—';

  const list = document.getElementById('days-list');
  list.innerHTML = '';
  if(!trip.days) return;
  trip.days.forEach(d => {
    const row = document.createElement('div');
    row.className = 'day-row';
    row.innerHTML = `
      <div class="day-col-left">
        <div class="day-num">${d.j}</div>
        <div class="day-date">${d.date}</div>
      </div>
      <div class="day-col-right">
        <div class="day-location">${d.lieu}</div>
        ${d.prog ? `<div class="day-program">${d.prog}</div>` : ''}
        ${d.hotel && d.hotel !== 'Avion' && d.hotel !== '' ? `<div class="day-hotel">${d.hotel}</div>` : ''}
        ${d.note ? `<div class="day-note">${d.note}</div>` : ''}
      </div>
    `;
    list.appendChild(row);
  });

  loadTripMap(trip);
  document.getElementById('itinerary').scrollIntoView({ behavior:'smooth' });
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function openModal() { document.getElementById('modal').classList.add('open'); }
function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.getElementById('modal').addEventListener('click', e => { if(e.target===e.currentTarget) closeModal(); });

function saveTrip() {
  const name = document.getElementById('f-name').value.trim();
  const dest = document.getElementById('f-dest').value.trim();
  const start = document.getElementById('f-start').value;
  const end = document.getElementById('f-end').value;
  const notes = document.getElementById('f-notes').value.trim();
  if(!name) return;

  const trip = {
    id: 'trip-'+Date.now(),
    name,
    dates: start && end ? `${start} → ${end}` : (start || end || ''),
    year: start ? start.slice(0,4) : '?',
    tags: dest ? dest.split(',').map(s=>s.trim()) : [],
    status: 'planned', statusLabel: 'Planifié',
    notes
  };
  extraTrips.push(trip);
  localStorage.setItem('wt-extra-trips', JSON.stringify(extraTrips));
  renderTripCards();
  closeModal();
  document.getElementById('f-name').value='';
  document.getElementById('f-dest').value='';
  document.getElementById('f-start').value='';
  document.getElementById('f-end').value='';
  document.getElementById('f-notes').value='';
}

// ── INIT ──────────────────────────────────────────────────────────────────────
document.getElementById('year').textContent = new Date().getFullYear();
renderTripCards();
loadItinerary(TRIPS[0]);
</script>
</body>
</html>
